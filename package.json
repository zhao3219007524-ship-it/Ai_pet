{
  "name": "pet-companion",
  "version": "0.1.0",
  "description": "AI-powered desktop pet with emotion learning",
  "main": "dist/main/index.js",
  "homepage": "./",
  "author": "your-name",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:react\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "tsc --noEmit && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0",
    "three": "^0.160.0",
    "better-sqlite3": "^9.2.2",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/three": "^0.160.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.0",
    "ts-node": "^10.9.0"
  }
}
